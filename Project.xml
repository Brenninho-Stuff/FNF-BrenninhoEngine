<?xml version="1.0" encoding="utf-8"?>
<project>

	<!-- _________________________ Application Settings _________________________ -->

	<!-- Desktop title -->
	<app title="Friday Night Funkin': Brenninho Engine"
	     file="BrenninhoEngine"
	     packageName="com.brenninho.fnfengine"
	     package="com.brenninho.fnfengine"
	     main="Main"
	     version="1.0.0"
	     company="Brenninho" />

	<!-- Override title on mobile -->
	<app title="FNF: BrenninhoEngine" if="mobile" />

	<!-- NOTE TO SELF: DISABLE THIS IF ISSUES ARE FOUND -->
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/> <!-- stable luas -->

	<app preloader="flixel.system.FlxPreloader" />

	<!-- Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2 -->
	<set name="SWF_VERSION" value="11.8" />

	<!-- _____________________ BRENNINHO ENGINE CUSTOMIZATION _____________________ -->

	<!-- Mod/scripting support: enabled on desktop AND android -->
	<define name="MODS_ALLOWED"    if="desktop || android" />
	<define name="HSCRIPT_ALLOWED" if="desktop || android" />
	<define name="LUA_ALLOWED"     if="desktop || android" />

	<!-- Always-on features -->
	<define name="ACHIEVEMENTS_ALLOWED" />
	<define name="TRANSLATIONS_ALLOWED" />
	<define name="IRIS_DEBUG" />
	<define name="MULTITHREADED_LOADING" />
	<define name="SHOW_LOADING_SCREEN" />
	<define name="PSYCH_WATERMARKS" />

	<!-- Discord: desktop only (hxdiscord_rpc doesn't support Android/iOS) -->
	<define name="DISCORD_ALLOWED" if="desktop" />

	<!-- Videos: available on desktop + Android (hxvlc 2.0.1 supports both).
	     Excluded from 32-bit builds and web. -->
	<define name="VIDEOS_ALLOWED" if="(windows || linux || android || mac) && !32bits" />

	<!-- Official build extras -->
	<section if="officialBuild">
		<define name="TITLE_SCREEN_EASTER_EGG" />
		<define name="BASE_GAME_FILES" />
	</section>

	<!-- __________________________ Android Settings ___________________________ -->

	<!-- Target SDK 34 (Android 14), minimum SDK 21 (Android 5.0 Lollipop) -->
	<android target-sdk-version="34" min-sdk-version="21" />

	<!-- Required permissions for Android -->
	<section if="android">
		<!-- External storage: needed to load mods from /sdcard/BrenninhoEngine/mods -->
		<template path="templates/android/AndroidManifest.xml" rename="AndroidManifest.xml" if="false" />
		<permission android:name="android.permission.READ_EXTERNAL_STORAGE"    if="android" />
		<permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"   if="android" />
		<permission android:name="android.permission.INTERNET"                 if="android" />
		<permission android:name="android.permission.VIBRATE"                  if="android" />
		<!-- Required for managing external storage on Android 11+ (API 30+) -->
		<permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"  if="android" />
	</section>

	<!-- __________________________ Window Settings ___________________________ -->

	<!-- Base window: all targets -->
	<window width="1280" height="720" fps="60" background="#000000"
	        hardware="true" vsync="false" allow-high-dpi="true" />

	<!-- HTML5 -->
	<window if="html5" resizable="true" />

	<!-- Desktop -->
	<window if="desktop" orientation="landscape" fullscreen="false"
	        resizable="true" vsync="false" />

	<!-- Mobile (Android/iOS): always fullscreen, use native resolution -->
	<window if="mobile" orientation="landscape" fullscreen="true"
	        width="0" height="0" resizable="false" />

	<!-- Switch -->
	<window if="switch" orientation="landscape" fullscreen="true"
	        width="0" height="0" resizable="true" />

	<!-- ___________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/debug"   if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit"   if="32bits" />

	<classpath name="source" />

	<!-- _________________________ Game Assets & Etc. _________________________ -->

	<!-- Crash handler: desktop release only -->
	<define name="CRASH_HANDLER" if="desktop release" />

	<!-- Core assets -->
	<assets path="assets/fonts" />

	<assets path="assets/shared"   exclude="*.ogg" if="web" />
	<assets path="assets/shared"   exclude="*.mp3" unless="web" />

	<assets path="assets/embed"    exclude="*.ogg" if="web"  embed="true" />
	<assets path="assets/embed"    exclude="*.mp3" unless="web" embed="true" />

	<assets path="assets/videos"   if="VIDEOS_ALLOWED" />

	<assets path="assets/songs"    exclude="*.ogg" if="web" />
	<assets path="assets/songs"    exclude="*.mp3" unless="web" />

	<assets path="assets/week_assets" rename="assets" exclude="*.ogg" if="web" />
	<assets path="assets/week_assets" rename="assets" exclude="*.mp3" unless="web" />

	<section if="TITLE_SCREEN_EASTER_EGG">
		<assets path="assets/secrets" rename="assets/shared" exclude="*.ogg" if="web" />
		<assets path="assets/secrets" rename="assets/shared" exclude="*.mp3" unless="web" />
	</section>

	<section if="TRANSLATIONS_ALLOWED">
		<assets path="assets/translations" rename="assets" exclude="*.ogg" if="web" />
		<assets path="assets/translations" rename="assets" exclude="*.mp3" unless="web" />
	</section>

	<section if="BASE_GAME_FILES">
		<assets path="assets/base_game" rename="assets" exclude="*.ogg" if="web" />
		<assets path="assets/base_game" rename="assets" exclude="*.mp3" unless="web" />
		<haxelib name="grig.audio"  if="BASE_GAME_FILES" />
		<haxelib name="funkin.vis"  if="BASE_GAME_FILES" />
	</section>

	<define name="CHECK_FOR_UPDATES" if="desktop officialBuild" />

	<section if="MODS_ALLOWED">
		<!-- Desktop: mods as template folder -->
		<assets path="example_mods" rename="mods" embed="false" type="template" unless="mac || android" />
		<assets path="example_mods" rename="mods" embed="false" if="mac" />
		<!-- Android: mods live on external storage; just ship the list file -->
		<assets path="list.txt" rename="modsList.txt" />
	</section>

	<assets path="art/readme.txt" rename="do NOT readme.txt" />

	<!-- OpenAL config (desktop) -->
	<section if="desktop">
		<assets path="alsoft.txt" rename="plugins/alsoft.ini"  type="text" if="windows" />
		<assets path="alsoft.txt" rename="plugins/alsoft.conf" type="text" unless="windows" />
	</section>

	<!-- ______________________________ Libraries ______________________________ -->

	<!-- HaxeFlixel — Psych Engine 0.7.x versions -->
	<haxelib name="flixel"         version="5.6.1" />
	<haxelib name="flixel-addons"  version="3.2.2" />
	<haxelib name="tjson"          version="1.4.0" />

	<!-- Psych-specific libs -->
	<haxelib name="linc_luajit"                          if="LUA_ALLOWED" />
	<haxelib name="hscript-iris"   version="1.1.3"       if="HSCRIPT_ALLOWED" />
	<haxelib name="hxvlc"          version="2.0.1"       if="VIDEOS_ALLOWED" />
	<haxelib name="hxdiscord_rpc"  version="1.2.4"       if="DISCORD_ALLOWED" />
	<haxelib name="flxanimate" />

	<!-- Disable Discord IO Thread (avoids hangs on exit) -->
	<haxedef name="DISCORD_DISABLE_IO_THREAD" if="hxdiscord_rpc" />

	<!-- Linux: skip precompiled headers -->
	<haxedef name="NO_PRECOMPILED_HEADERS" if="linux" />

	<!-- Debug server -->
	<haxelib name="hxcpp-debug-server" if="debug" />

	<!-- VLC debug logging -->
	<haxedef name="HXC_LIBVLC_LOGGING"      if="VIDEOS_ALLOWED debug" />
	<haxedef name="HXVLC_NO_SHARE_DIRECTORY" if="VIDEOS_ALLOWED" />

	<!-- 32-bit define -->
	<define name="x86_BUILD" if="32bits" />

	<!-- _________________________ Android-specific Haxedefs _________________________ -->

	<section if="android">
		<!-- Use OpenGL ES 3.0 on Android for better performance -->
		<haxedef name="OPENFL_GLES3_CONTEXT" />
		<!-- Disable deprecated lime/openfl warnings that spam logcat -->
		<haxedef name="no-deprecation-warnings" />
	</section>

	<!-- _____________________________ Haxedefines _____________________________ -->

	<!-- Flixel: disable unused subsystems on mobile to save memory -->
	<haxedef name="FLX_NO_TOUCH"         if="desktop" />
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG"         unless="debug" />
	<haxedef name="NAPE_RELEASE_BUILD"   unless="debug" />

	<!-- Crash handler hxcpp stack info -->
	<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_LINE"    if="CRASH_HANDLER" />
	<haxedef name="HXCPP_STACK_TRACE"   if="CRASH_HANDLER" />

	<!-- Suppress deprecation warnings -->
	<haxedef name="no-deprecation-warnings" />

	<!-- Pretty compiler messages (Haxe 4.3.0+) -->
	<haxedef name="message.reporting" value="pretty" />

	<!-- HXC debug trace -->
	<haxedef name="HXC_DEBUG_TRACE" if="debug" />

	<!-- Macro fixes -->
	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />

	<!-- HScript position tracking -->
	<haxedef name="hscriptPos" if="HSCRIPT_ALLOWED" />

	<!-- ________________________________ Icons ________________________________ -->

	<assets path="art/icons/iconOG.png" rename="icon.png" if="linux || mac" />
	<icon path="art/icons/icon16.png"  size="16" />
	<icon path="art/icons/icon32.png"  size="32" />
	<icon path="art/icons/icon64.png"  size="64" />
	<icon path="art/icons/iconOG.png" />

</project>
